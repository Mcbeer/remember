{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "remember",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-06-07",
  // Serve production on the custom domain (Cloudflare provisions the DNS record
  // and TLS cert for this hostname on the hornskov.dev zone).
  "routes": [
    {
      "pattern": "remember.hornskov.dev",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  },
  // Reminder scheduler: every minute, find due Reminders and send Web Push.
  "triggers": {
    "crons": ["* * * * *"]
  },
  // Workers AI: the on-platform LLM that extracts suggested Items from inbound
  // email (Email Ingestion, ADR-0005).
  "ai": {
    "binding": "AI"
  },
  // The domain part of every List's inbound address (`${secret}@${INBOX_DOMAIN}`).
  // Email Routing is enabled on the apex `hornskov.dev` zone with a catch-all
  // rule delivering to this Worker's email() handler, so addresses live on the
  // apex directly (e.g. `groceries-a8f3@hornskov.dev`).
  "vars": {
    "INBOX_DOMAIN": "hornskov.dev"
  },
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "remember",
      "database_id": "92f094d4-2ab2-44f1-a25c-1c575113eb77",
      "migrations_dir": "migrations"
    }
  ]
}
